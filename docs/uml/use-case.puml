@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor Student
actor Admin
actor "Queue Display" as QueueScreen

rectangle "SmartCanteen System" {
  usecase "Sign Up" as UC1
  usecase "Login" as UC2
  usecase "Browse Menu" as UC3
  usecase "Add Items to Cart" as UC4
  usecase "Place Order" as UC5
  usecase "Pay for Order" as UC6
  usecase "Track Queue / Order Status" as UC7
  usecase "Cancel Own Order" as UC8

  usecase "Manage Menu\n(Create/Update/Delete/Toggle)" as UC9
  usecase "Manage Orders\n(View/Filter/Update Status)" as UC10
  usecase "View Dashboard Stats" as UC11
  usecase "Manage Payments\n(View/Refund)" as UC12

  usecase "Receive Realtime Queue Updates" as UC13
}

Student --> UC1
Student --> UC2
Student --> UC3
Student --> UC4
Student --> UC5
Student --> UC6
Student --> UC7
Student --> UC8

Admin --> UC2
Admin --> UC3
Admin --> UC9
Admin --> UC10
Admin --> UC11
Admin --> UC12
Admin --> UC13

QueueScreen --> UC13

UC5 .> UC3 : <<include>>
UC5 .> UC4 : <<include>>
UC6 .> UC5 : <<extend>>
UC7 .> UC13 : <<include>>
UC10 .> UC13 : <<include>>

@enduml